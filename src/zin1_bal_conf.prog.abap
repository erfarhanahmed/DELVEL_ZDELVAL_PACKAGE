  SELECT-OPTIONS : PROCENT  FOR BSID-PRCTR ."MODIF ID ID1.
  SELECT-OPTIONS : CUSTNO   FOR BSID-KUNNR ."MODIF ID ID2.
  SELECT-OPTIONS : VENDORNO FOR BSIK-LIFNR.
  PARAMETERS: POSTDATE TYPE BSID-BUDAT OBLIGATORY ."NO-EXTENSION OBLIGATORY.
*SELECT-OPTIONS : POSTDATE FOR BSID-BUDAT NO-EXTENSION OBLIGATORY.
  PARAMETERS     : CURRENCY TYPE BSID-WAERS OBLIGATORY.
SELECTION-SCREEN: END OF BLOCK SEL.

