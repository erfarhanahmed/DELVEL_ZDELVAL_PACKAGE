          .

        CUST_BAL = T_AMOUNT * 10.
**      WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - CUST_BAL.
        WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-WRBTR.
        MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING CLBAL WHERE KUNNR = WA_FINAL-KUNNR.
      ELSE.

        "uncommented
*     WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-dmbtr.
**      WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-dmbtr.
        WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-WRBTR.
        MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING CLBAL WHERE KUNNR = WA_FINAL-KUNNR.
      ENDIF.
      """"""
*      WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-DMBTR.
*      MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING CLBAL WHERE KUNNR = WA_FINAL-KUNNR.
    ENDIF.

    READ TABLE IT_BSEGCCPC INTO WA_BSEGCCPC WITH KEY BUKRS = WA_FINAL-BUKRS BELNR = WA_FINAL-BELNR GJAHR = WA_FINAL-GJAHR.
    IF WA_FINAL-KOSTL IS INITIAL AND WA_BSEGCCPC IS NOT INITIAL.
      WA_FINAL-KOSTL = WA_BSEGCCPC-KOSTL.
    ENDIF.
    IF WA_FINAL-PRCTR IS INITIAL AND WA_BSEGCCPC IS NOT INITIAL.
      WA_FINAL-PRCTR = WA_BSEGCCPC-PRCTR.
    ENDIF.

    IF WA_FINAL-KUNNR IS NOT INITIAL.
      READ TABLE IT_BSEGAC INTO WA_BSEGAC WITH KEY BUKRS = WA_FINAL-BUKRS BELNR = WA_FINAL-BELNR GJAHR = WA_FINAL-GJAHR.
      WA_FINAL-SAKNR = WA_BSEGAC-HKONT.

      WA_CUSTBAL-GJAHR = WA_BSEGAC-GJAHR .

      MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING GJAHR WHERE KUNNR = WA_FINAL-KUNNR.

      READ TABLE IT_SKAT INTO WA_SKAT WITH KEY SAKNR = WA_FINAL-SAKNR.
      WA_FINAL-GLT20 = WA_SKAT-TXT20.
      WA_FINAL-GLT50 = WA_SKAT-TXT50.
      CLEAR WA_SKAT.
    ENDIF.

    READ TABLE IT_BKPF INTO WA_BKPF WITH KEY BUKRS = WA_FINAL-BUKRS BELNR = WA_FINAL-BELNR GJAHR = WA_FINAL-GJAHR.
    CALL FUNCTION 'FI_CONVERT_FIRSTCHARS_TOUPPER'
      EXPORTING
