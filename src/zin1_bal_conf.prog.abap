    READ TABLE IT_PAYR INTO WA_PAYR WITH KEY ZBUKR = WA_FINAL-BUKRS VBLNR = WA_FINAL-BELNR GJAHR = WA_FINAL-GJAHR.
    WA_FINAL-CHECT = WA_PAYR-CHECT.

    READ TABLE IT_CSKT INTO WA_CSKT WITH KEY KOSTL = WA_FINAL-KOSTL.
    WA_FINAL-CNAME = WA_CSKT-KTEXT.

    READ TABLE IT_CEPCT INTO WA_CEPCT WITH KEY PRCTR = WA_FINAL-PRCTR.
    WA_FINAL-PNAME = WA_CEPCT-KTEXT.
