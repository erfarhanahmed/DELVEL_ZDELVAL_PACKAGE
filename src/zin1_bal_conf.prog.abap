        VEND_BAL = T_AMOUNT * 10.
        IF WA_BSID-SHKZG = 'S'.
**      WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL + VEND_BAL.
          WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL + WA_BSID-WRBTR..
        ELSEIF WA_BSID-SHKZG = 'H'.
**        WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - VEND_BAL.
          WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-WRBTR.
        ENDIF.
        MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING CLBAL WHERE KUNNR = WA_FINAL-KUNNR.
      ELSE.
        IF WA_BSID-SHKZG = 'S'.
**       WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL + WA_BSID-dmbtr.
          WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL + WA_BSID-WRBTR.
        ELSEIF WA_BSID-SHKZG = 'H'.
**         WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-dmbtr.
          WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL - WA_BSID-WRBTR.
        ENDIF.

        MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING CLBAL WHERE KUNNR = WA_FINAL-KUNNR.
      ENDIF.
      """""""""
*      WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL + WA_BSID-DMBTR.
*      MODIFY IT_CUSTBAL FROM WA_CUSTBAL TRANSPORTING CLBAL WHERE KUNNR = WA_FINAL-KUNNR.
    ELSE.
*      WA_FINAL-CREDIT = WA_BSID-DMBTR.
      IF CURRENCY EQ 'USD' OR CURRENCY EQ 'EUR'.
        CLEAR : RATE,V_AMOUNT,DEB_AMT.
*      SELECT SINGLE UKURS FROM TCURR INTO RATE WHERE FCURR = 'INR' AND KURST = 'M' AND TCURR = CURRENCY.
*        RATE = RATE * -1.
        SELECT SINGLE KURSF FROM BKPF INTO RATE WHERE
                    BUKRS = WA_BSID-BUKRS AND BELNR = WA_BSID-BELNR AND GJAHR = WA_BSID-GJAHR.

        CALL FUNCTION 'CONVERT_CURRENCY_BY_RATE'
          EXPORTING
            FROM_AMOUNT   = WA_BSID-WRBTR                       " WA_BSID-DMBTR
            FROM_CURRENCY = 'INR'
            FROM_FACTOR   = '1'
            RATE          = RATE
            TO_CURRENCY   = CURRENCY
            TO_FACTOR     = '1'
          IMPORTING
            TO_AMOUNT     = V_AMOUNT
*        EXCEPTIONS
*           NO_RATE_FOUND = 1
*           OTHERS        = 2
          .

*****      DEB_AMT = V_AMOUNT . "* 10.
        WA_FINAL-DEBIT =  WA_BSID-WRBTR.  "DEB_AMT.
        WA_FINAL-DEBIT =  WA_FINAL-DEBIT * -1.
*       WA_FINAL-CREDIT = DEB_AMT.
      ELSE.
        WA_FINAL-DEBIT = - WA_BSID-WRBTR .                  "WA_BSID-DMBTR.

        "commented by sneha 29/05/2018
*       WA_FINAL-DEBIT = WA_FINAL-DEBIT * -1.

        "by sneha 29/05/2018
        WA_FINAL-CREDIT = WA_BSID-DMBTR.
        WA_FINAL-CREDIT = WA_FINAL-CREDIT * -1.
      ENDIF.


      READ TABLE IT_CUSTBAL INTO WA_CUSTBAL WITH KEY KUNNR = WA_FINAL-KUNNR.
      """"""""
      IF CURRENCY EQ 'USD' OR CURRENCY EQ 'EUR'.
        CLEAR : T_RATE,T_AMOUNT,VEND_BAL.
        SELECT SINGLE KURSF FROM BKPF INTO T_RATE WHERE
        BUKRS = WA_BSID-BUKRS AND BELNR = WA_BSID-BELNR AND GJAHR = WA_BSID-GJAHR.
*     T_RATE = T_RATE * -1.
        CALL FUNCTION 'CONVERT_CURRENCY_BY_RATE'
          EXPORTING
            FROM_AMOUNT   = WA_BSID-DMBTR
            FROM_CURRENCY = 'INR'
            FROM_FACTOR   = '1'
            RATE          = T_RATE
            TO_CURRENCY   = CURRENCY
            TO_FACTOR     = '1'
          IMPORTING
            TO_AMOUNT     = T_AMOUNT
*        EXCEPTIONS
*           NO_RATE_FOUND = 1
