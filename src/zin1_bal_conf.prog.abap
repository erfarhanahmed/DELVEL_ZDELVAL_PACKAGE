FORM SELECT_DATA.

  IF CUST IS NOT INITIAL AND VENDORNO-LOW IS NOT INITIAL.

    MESSAGE 'Please Select Correct Radio Button' TYPE 'E' DISPLAY LIKE 'W'.

  ENDIF.

  DATA:
    IT_KEYBALANCE TYPE STANDARD TABLE OF BAPI3008_3,
    WA_KEYBALANCE TYPE BAPI3008_3,
    KEY_DATE      TYPE DATUM.

  SELECT BUKRS
         KUNNR
         UMSKS
         UMSKZ
         AUGDT
         AUGBL
         ZUONR
         GJAHR
         BELNR
         BUZEI
         BUDAT
         BLDAT
         XBLNR
         BLART
         BSCHL
         SHKZG
         GSBER
         DMBTR
         WRBTR
         SGTXT
         HKONT
         ZFBDT
         KOSTL
         PRCTR
         BUPLA
         SECCO
    FROM BSID
    INTO TABLE IT_BSID
    WHERE BUKRS EQ COMPCODE
     AND WAERS EQ CURRENCY
     AND KUNNR IN R_CUSTNO
     AND BUDAT LE POSTDATE
     AND PRCTR IN PROCENT.
*     AND BLART NE 'AB'.


  IF CUST IS NOT INITIAL AND VENDORNO-LOW IS NOT INITIAL.

    MESSAGE 'Please Select Correct Radio Button' TYPE 'E'.

  ENDIF.


  SELECT BUKRS
         KUNNR
         UMSKS
         UMSKZ
         AUGDT
         AUGBL
         ZUONR
         GJAHR
         BELNR
         BUZEI
         BUDAT
         BLDAT
         XBLNR
         BLART
         BSCHL
         SHKZG
         GSBER
         DMBTR
         WRBTR
         SGTXT
         HKONT
         ZFBDT
         KOSTL
         PRCTR
         BUPLA
         SECCO
    FROM BSAD
    INTO TABLE IT_BSAD
    WHERE BUKRS EQ COMPCODE
     AND WAERS EQ CURRENCY
     AND KUNNR IN CUSTNO
     AND BUDAT LE POSTDATE
*     AND AUGDT LE POSTDATE
    AND  AUGDT > POSTDATE
    AND PRCTR IN PROCENT.
  APPEND LINES OF IT_BSAD TO IT_BSID.
*     AND BLART NE 'AB'.
***DELETE IT_BSAD WHERE BUDAT > POSTDATE.

*  LOOP AT IT_BSAD INTO WA_BSAD." WHERE BLART = 'AB'.
*    SELECT SUM( DMBTR ) FROM BSAD INTO CR_CHK WHERE BELNR = WA_BSAD-BELNR AND KUNNR = WA_BSAD-KUNNR AND SHKZG = 'H'.
*    SELECT SUM( DMBTR ) FROM BSAD INTO DR_CHK WHERE BELNR = WA_BSAD-BELNR AND KUNNR = WA_BSAD-KUNNR AND SHKZG = 'S'.
*    IF CR_CHK = DR_CHK AND WA_BSAD-BELNR = WA_BSAD-AUGBL.
*      DELETE IT_BSAD WHERE BELNR = WA_BSAD-BELNR AND KUNNR = WA_BSAD-KUNNR.
*    ENDIF.
*  ENDLOOP.
*
*  APPEND LINES OF IT_BSAD TO IT_BSID.
  SORT IT_BSID ASCENDING BY KUNNR BUDAT BELNR.


  IF NOT IT_BSID IS INITIAL.
    SELECT BUKRS BELNR GJAHR BKTXT FROM BKPF INTO TABLE IT_BKPF FOR ALL ENTRIES IN IT_BSID
      WHERE BUKRS = IT_BSID-BUKRS AND BELNR = IT_BSID-BELNR AND GJAHR = IT_BSID-GJAHR.

    SELECT BUKRS BELNR GJAHR BUZEI DMBTR KOSTL HKONT KUNNR LIFNR PRCTR FROM BSEG INTO TABLE IT_BSEG FOR ALL ENTRIES IN IT_BSID
      WHERE BUKRS = IT_BSID-BUKRS AND BELNR = IT_BSID-BELNR AND GJAHR = IT_BSID-GJAHR. "#EC CI_NOORDER

    APPEND LINES OF IT_BSEG TO IT_BSEGCCPC.
    DELETE IT_BSEGCCPC WHERE KOSTL = '' AND PRCTR = ''.
    APPEND LINES OF IT_BSEG TO IT_BSEGAC.
    DELETE IT_BSEGAC WHERE KUNNR <> ''.
    SORT IT_BSEGAC DESCENDING BY BELNR DMBTR.
    DELETE ADJACENT DUPLICATES FROM IT_BSEGAC COMPARING BELNR.

    SELECT SPRAS KTOPL SAKNR TXT20 TXT50 FROM SKAT INTO TABLE IT_SKAT FOR ALL ENTRIES IN IT_BSEG
      WHERE  SPRAS = 'E' AND KTOPL = COMPCODE AND SAKNR = IT_BSEG-HKONT.

    SELECT KUNNR NAME1 ORT01 PSTLZ STRAS REGIO LAND1 TELF1 ADRNR FROM KNA1 INTO CORRESPONDING FIELDS OF TABLE IT_KNA1
      FOR ALL ENTRIES IN IT_BSID
      WHERE KUNNR = IT_BSID-KUNNR.
    SELECT  ADDRNUMBER
            STR_SUPPL1
            STR_SUPPL2
            STR_SUPPL3
            STREET
            HOUSE_NUM1
            LOCATION FROM ADRC INTO TABLE IT_ADRC
      FOR ALL ENTRIES IN IT_LFA1
       WHERE ADDRNUMBER = IT_LFA1-ADRNR.
    SELECT SPRAS LAND1 LANDX FROM T005T INTO TABLE IT_T005T FOR ALL ENTRIES IN IT_KNA1
                                                       WHERE LAND1 = IT_KNA1-LAND1 AND SPRAS = 'EN'.

    SELECT SPRAS BLAND BEZEI FROM T005U INTO TABLE IT_T005U FOR ALL ENTRIES IN IT_KNA1
      WHERE SPRAS = 'EN' AND BLAND = IT_KNA1-REGIO AND LAND1 = IT_KNA1-LAND1.

    SELECT ZBUKR CHECT VBLNR GJAHR FROM PAYR INTO TABLE IT_PAYR FOR ALL ENTRIES IN IT_BSID
      WHERE ZBUKR = IT_BSID-BUKRS AND VBLNR = IT_BSID-BELNR AND GJAHR = IT_BSID-GJAHR.

    SELECT SPRAS KOKRS KOSTL KTEXT LTEXT FROM CSKT INTO TABLE IT_CSKT FOR ALL ENTRIES IN IT_BSID
      WHERE SPRAS = 'E' AND KOKRS = COMPCODE AND KOSTL = IT_BSID-KOSTL.

    SELECT SPRAS KOKRS KOSTL KTEXT LTEXT FROM CSKT APPENDING TABLE IT_CSKT FOR ALL ENTRIES IN IT_BSEGCCPC
      WHERE SPRAS = 'E' AND KOKRS = COMPCODE AND KOSTL = IT_BSEGCCPC-KOSTL.

    SELECT SPRAS PRCTR KOKRS KTEXT LTEXT FROM CEPCT INTO TABLE IT_CEPCT FOR ALL ENTRIES IN IT_BSID
      WHERE SPRAS = 'E' AND KOKRS = COMPCODE AND PRCTR = IT_BSID-PRCTR.

    SELECT SPRAS PRCTR KOKRS KTEXT LTEXT FROM CEPCT APPENDING TABLE IT_CEPCT FOR ALL ENTRIES IN IT_BSEGCCPC
      WHERE SPRAS = 'E' AND KOKRS = COMPCODE AND PRCTR = IT_BSEGCCPC-PRCTR.
  ENDIF.

  LOOP AT IT_KNA1 INTO WA_KNA1.
    WA_CUSTBAL-KUNNR = WA_KNA1-KUNNR.
    WA_CUSTBAL-NAME1 = WA_KNA1-NAME1.
    WA_CUSTBAL-STRAS = WA_KNA1-STRAS.
    WA_CUSTBAL-ORT01 = WA_KNA1-ORT01.
    WA_CUSTBAL-PSTLZ = WA_KNA1-PSTLZ.
    WA_CUSTBAL-TELF1 = WA_KNA1-TELF1.
*        WA_CUSTBAL-telf2 = wa_kna1-telf2.
    READ TABLE IT_ADRC INTO LS_ADRC WITH KEY ADDRNUMBER = WA_KNA1-ADRNR.
    WA_CUSTBAL-STR_SUPPL1 = LS_ADRC-STR_SUPPL1.
    WA_CUSTBAL-STR_SUPPL2 = LS_ADRC-STR_SUPPL2.
    WA_CUSTBAL-STR_SUPPL3 = LS_ADRC-STR_SUPPL3.
    WA_CUSTBAL-STREET = LS_ADRC-STREET.
    WA_CUSTBAL-HOUSE_NUM1 = LS_ADRC-HOUSE_NUM1.
    WA_CUSTBAL-LOCATION = LS_ADRC-LOCATION.
    READ TABLE IT_T005T INTO WA_T005T WITH KEY LAND1 = WA_KNA1-LAND1.
    WA_CUSTBAL-LANDX = WA_T005T-LANDX.

    READ TABLE IT_T005U INTO WA_T005U WITH KEY BLAND = WA_KNA1-REGIO.
    WA_CUSTBAL-BEZEI = WA_T005U-BEZEI.

    CALL FUNCTION 'BAPI_AR_ACC_GETKEYDATEBALANCE'
      EXPORTING
        COMPANYCODE  = COMPCODE
        CUSTOMER     = WA_KNA1-KUNNR
        KEYDATE      = KEY_DATE
        BALANCESPGLI = ABAP_TRUE
        NOTEDITEMS   = ABAP_TRUE
      TABLES
        KEYBALANCE   = IT_KEYBALANCE.

    LOOP AT IT_KEYBALANCE INTO WA_KEYBALANCE.
      IF CURRENCY = WA_KEYBALANCE-CURRENCY.
        WA_CUSTBAL-OPBAL = WA_CUSTBAL-OPBAL + WA_KEYBALANCE-LC_BAL.
      ENDIF.
    ENDLOOP.
****************************************************
    IF CURRENCY EQ 'EUR' OR CURRENCY EQ 'USD'.
      CLEAR W_BSID.
      READ TABLE IT_BSID INTO W_BSID WITH KEY KUNNR = WA_CUSTBAL-KUNNR.
      CLEAR : CL_RATE,CL_AMOUNT,CL_BAL.
      SELECT SINGLE KURSF FROM BKPF INTO CL_RATE WHERE
          BUKRS = W_BSID-BUKRS AND BELNR = W_BSID-BELNR AND GJAHR = W_BSID-GJAHR.

      CALL FUNCTION 'CONVERT_CURRENCY_BY_RATE'
        EXPORTING
          FROM_AMOUNT   = WA_CUSTBAL-OPBAL
          FROM_CURRENCY = 'INR'
          FROM_FACTOR   = '1'
          RATE          = CL_RATE
          TO_CURRENCY   = CURRENCY
          TO_FACTOR     = '1'
        IMPORTING
          TO_AMOUNT     = CL_AMOUNT
*        EXCEPTIONS
*         NO_RATE_FOUND = 1
*         OTHERS        = 2
        .

      CL_BAL = CL_AMOUNT * 10.
      WA_CUSTBAL-OPBAL = CL_BAL.

      WA_CUSTBAL-CLBAL = WA_CUSTBAL-OPBAL.

    ELSE.
      WA_CUSTBAL-CLBAL = WA_CUSTBAL-OPBAL.
    ENDIF.

****************************************************

*    WA_CUSTBAL-CLBAL = WA_CUSTBAL-OPBAL.
*    WA_CUSTBAL-OPDATE = POSTDATE-LOW.
*    WA_CUSTBAL-CLDATE = POSTDATE-HIGH.
    WA_CUSTBAL-CLDATE = POSTDATE.
    APPEND WA_CUSTBAL TO IT_CUSTBAL.
    CLEAR: WA_CUSTBAL, IT_KEYBALANCE, WA_KNA1.
