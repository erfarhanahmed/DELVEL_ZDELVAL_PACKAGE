  LS_HEADER-OBJECT     = LV_OBJ.
  LS_HEADER-ALDATE     = SY-DATUM.
  LS_HEADER-ALTIME     = SY-UZEIT.
  LS_HEADER-ALUSER     = SY-UNAME.


* Get the Log handle using the header
  CALL FUNCTION 'APPL_LOG_WRITE_HEADER'
    EXPORTING
      HEADER              = LS_HEADER
    IMPORTING
      E_LOG_HANDLE        = LV_LOG_HANDLE
    EXCEPTIONS
      OBJECT_NOT_FOUND    = 1
      SUBOBJECT_NOT_FOUND = 2
      ERROR               = 3
      OTHERS              = 4.
  IF SY-SUBRC <> 0.
    "Message Text: Error while writing Log header data.
    GS_MSG-MSGTY = 'E'.
    GS_MSG-MSGID = 'ZFI_CONF'.
    GS_MSG-MSGNO = '004'.
    APPEND GS_MSG TO GT_MSG.


  ENDIF.

* Get the next avalaible Log number
  CALL FUNCTION 'BAL_DB_LOGNUMBER_GET'
    EXPORTING
      I_CLIENT                 = SY-MANDT
      I_LOG_HANDLE             = LV_LOG_HANDLE
    IMPORTING
      E_LOGNUMBER              = LV_LOG_NUMBER
    EXCEPTIONS
      LOG_NOT_FOUND            = 1
      LOGNUMBER_ALREADY_EXISTS = 2
      NUMBERING_ERROR          = 3
      OTHERS                   = 4.
  IF SY-SUBRC <> 0.
    "Message Text: Next available Log number not generated.
*        gs_msg-msgty = 'E'.
*        gs_msg-msgid = 'ZFI_CONF'.
*        gs_msg-msgno = '001'.
*        APPEND gs_msg TO gt_msg.


  ENDIF.


* write the Log messages to the memory
  CALL FUNCTION 'APPL_LOG_WRITE_MESSAGES'
    EXPORTING
      OBJECT              = LV_OBJ
      LOG_HANDLE          = LV_LOG_HANDLE
    TABLES
      MESSAGES            = GT_MSG
    EXCEPTIONS
      OBJECT_NOT_FOUND    = 1
      SUBOBJECT_NOT_FOUND = 2
      OTHERS              = 3.
  IF SY-SUBRC <> 0.
    "Message Text: Log not found (in main memory).
    GS_MSG-MSGTY = 'E'.
    GS_MSG-MSGID = 'BL'.
    GS_MSG-MSGNO = '207'.
    APPEND GS_MSG TO GT_MSG.


  ENDIF.

* write the log message to Database which can be later analyzed from transaction SLG1
  MOVE-CORRESPONDING LS_HEADER TO LS_LOGNUM.
  LS_LOGNUM-LOGNUMBER = LV_LOG_NUMBER.
  APPEND LS_LOGNUM TO LT_LOGNUM.

  CALL FUNCTION 'APPL_LOG_WRITE_DB'
    EXPORTING
      OBJECT                = LV_OBJ
      LOG_HANDLE            = LV_LOG_HANDLE
    TABLES
      OBJECT_WITH_LOGNUMBER = LT_LOGNUM
    EXCEPTIONS
      OBJECT_NOT_FOUND      = 1
      SUBOBJECT_NOT_FOUND   = 2
      INTERNAL_ERROR        = 3
      OTHERS                = 4.
  IF SY-SUBRC <> 0.
    "Message Text: No log was created for object &.
    GS_MSG-MSGTY = 'E'.
    GS_MSG-MSGID = 'BL'.
    GS_MSG-MSGNO = '007'.
    GS_MSG-MSGV1 = LV_OBJ.
    APPEND GS_MSG TO GT_MSG.
    CLEAR : GS_MSG.


  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*& Form send_mail
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM SEND_MAIL .
  DATA: LX_DOCUMENT_BCS TYPE REF TO CX_DOCUMENT_BCS VALUE IS INITIAL.
  CLASS CL_BCS DEFINITION LOAD.

  DATA: LO_SEND_REQUEST TYPE REF TO CL_BCS VALUE IS INITIAL.
  LO_SEND_REQUEST = CL_BCS=>CREATE_PERSISTENT( ).

* Message body and subject

  DATA: LT_MESSAGE_BODY TYPE BCSY_TEXT VALUE IS INITIAL,
        LO_DOCUMENT     TYPE REF TO CL_DOCUMENT_BCS VALUE IS INITIAL,
        WA_BODY         TYPE SOLI.

  APPEND 'Dear Sir/Madam,' TO LT_MESSAGE_BODY.
  APPEND ' ' TO LT_MESSAGE_BODY.

  WA_BODY-LINE = LV_TEXT .

  APPEND WA_BODY TO LT_MESSAGE_BODY .

  APPEND ' ' TO LT_MESSAGE_BODY.
  APPEND ' ' TO LT_MESSAGE_BODY.

  APPEND 'Thanks & Regards,' TO LT_MESSAGE_BODY.
  APPEND 'DELVAL Flow Controls Pvt Ltd' TO LT_MESSAGE_BODY.



  LO_DOCUMENT = CL_DOCUMENT_BCS=>CREATE_DOCUMENT(
    I_TYPE    = 'RAW'
    I_TEXT    = LT_MESSAGE_BODY
    I_SUBJECT = 'Balance Confirmation' ).


  TRY.

      LO_DOCUMENT->ADD_ATTACHMENT(
        EXPORTING
          I_ATTACHMENT_TYPE    = 'PDF'
          I_ATTACHMENT_SUBJECT = 'Balance Confirmation'
          I_ATT_CONTENT_HEX    = LT_BCS_PDF ).

    CATCH CX_DOCUMENT_BCS INTO LX_DOCUMENT_BCS.

  ENDTRY.
  LO_SEND_REQUEST->SET_DOCUMENT( LO_DOCUMENT ).

  DATA: LO_SENDER TYPE REF TO IF_SENDER_BCS VALUE IS INITIAL,

        L_SEND    TYPE ADR6-SMTP_ADDR.

  LO_SENDER = CL_CAM_ADDRESS_BCS=>CREATE_INTERNET_ADDRESS( 'balance.confirmation@delvalflow.com' ).

*  lo_sender = cl_sapuser_bcs=>create( sy-uname ).

* Set sender

  LO_SEND_REQUEST->SET_SENDER(
    EXPORTING
      I_SENDER = LO_SENDER ).


  DATA:

  LO_RECIPIENT TYPE REF TO IF_RECIPIENT_BCS VALUE IS INITIAL.


  IF I_RECLIST IS NOT INITIAL .
    LOOP AT I_RECLIST INTO DATA(W_REC).
      CLEAR : LV_SMTP_ADDR.
      LV_SMTP_ADDR = W_REC-RECEIVER .


      LO_RECIPIENT = CL_CAM_ADDRESS_BCS=>CREATE_INTERNET_ADDRESS( LV_SMTP_ADDR ).
      IF   W_REC-COPY EQ SPACE .
** Set recipient
        LO_SEND_REQUEST->ADD_RECIPIENT(
          EXPORTING
            I_RECIPIENT = LO_RECIPIENT
            I_EXPRESS   = 'X' ).

      ELSE.

        LO_SEND_REQUEST->ADD_RECIPIENT(
          EXPORTING
            I_RECIPIENT = LO_RECIPIENT
            I_COPY      = 'X'
            I_EXPRESS   = 'X' ).

      ENDIF.
      CLEAR : W_REC .
    ENDLOOP.

*  lo_send_request->add_recipient(

*  EXPORTING

*  i_recipient = lo_recipient

*  i_express = 'X' ).

* Send email

    DATA: LV_SENT_TO_ALL(1) TYPE C VALUE IS INITIAL.

    LO_SEND_REQUEST->SEND(
      EXPORTING
        I_WITH_ERROR_SCREEN = 'X'
      RECEIVING
        RESULT              = LV_SENT_TO_ALL ).

    COMMIT WORK.

  ENDIF.
ENDFORM.
